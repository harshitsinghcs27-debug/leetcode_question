class Solution {
    int max = 0;

    public int maxDepth(TreeNode root) {
        dfs(root, 0);
        return max;
    }

    void dfs(TreeNode root, int d) {
        if (root == null) return;

        d++;
        max = Math.max(max, d);

        dfs(root.left, d);
        dfs(root.right, d);
    }
}
